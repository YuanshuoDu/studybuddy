# Mavis local-only artifacts — never commit these
.harness/
.mavis/

# Tooling / build artifacts
miniprogram/node_modules/
# Flutter local-build output (auto-generated by `flutter run` / `flutter build`)
app/.dart_tool/
app/.flutter-plugins
app/.flutter-plugins-dependencies
app/android/.gradle/
app/android/app/build/
app/android/local.properties
app/android/key.properties
app/android/app/src/main/java/io/flutter/plugins/GeneratedPluginRegistrant.java
app/ios/Flutter/GeneratedPluginRegistrant.*
app/ios/Pods/
app/ios/.symlinks/
app/ios/Flutter/flutter_export_environment.sh
app/build/
app/.idea/
app/.vscode/
# Flutter web scaffold (regenerated by `flutter create --platforms=web`).
# The `flutter create` overlay overwrites app/README.md and
# app/test/widget_test.dart with generic placeholders — never commit
# those overlays, restore the originals if you need them.
app/ios/Flutter/
app/ios/Runner/GeneratedPluginRegistrant.h
app/ios/Runner/GeneratedPluginRegistrant.m
app/test/widget_test.dart
app/web/
# `flutter create` regenerates this every time the SDK layout changes.
app/.metadata
app/README.md