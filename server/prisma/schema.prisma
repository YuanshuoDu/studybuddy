// Pairhub Prisma schema
// Spec alignment: docs/spec-v0.2.md §5 (User / Activity / Signup) and §13 (Review, M3 stub).
// Postgres 16 + Prisma 5.20+

generator client {
  provider        = "prisma-client-js"
  previewFeatures = []
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =====================================================================
// Users
// =====================================================================

enum UserStatus {
  ACTIVE
  BANNED
}

model User {
  id        String     @id @default(cuid())
  openid    String     @unique
  unionid   String?    @unique
  nickname  String
  avatar    String?
  school    String?
  major     String?
  grade     String?
  wechatId  String?    @map("wechat_id")
  phone     String?    @unique
  bio       String?    @db.VarChar(500)
  status    UserStatus @default(ACTIVE)
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  activities Activity[] @relation("creator")
  signups    Signup[]
  pushTokens PushToken[]

  @@index([school, grade])
  @@index([status])
  @@map("users")
}

// =====================================================================
// Activities
// =====================================================================

enum ActivityType {
  STUDY
  SPORTS
  BOARD_GAME
  ONLINE_GAME
  OTHER
}

enum ActivityStatus {
  RECRUITING
  FULL
  STARTED
  ENDED
  CANCELED
}

enum ContentCheckStatus {
  PENDING
  PASS
  BLOCKED
}

model Activity {
  id              String             @id @default(cuid())
  creatorId       String             @map("creator_id")
  creator         User               @relation("creator", fields: [creatorId], references: [id])
  type            ActivityType
  title           String             @db.VarChar(100)
  description     String             @db.VarChar(2000)
  coverUrl        String?            @map("cover_url")
  locationName    String             @map("location_name")
  locationAddr    String             @map("location_addr")
  // WGS-84 (international standard; same coordinate system as Mapbox).
  // Decimal(10,7) is precise to ~1cm. The original source was GCJ-02
  // (Tencent) but PR #37 (mapbox-migration) standardized on WGS-84.
  // Geo queries in modules/activity/index.ts cast to float8 for trig.
  locationLat     Decimal            @map("location_lat") @db.Decimal(10, 7)
  locationLng     Decimal            @map("location_lng") @db.Decimal(10, 7)
  startTime       DateTime           @map("start_time")
  endTime         DateTime           @map("end_time")
  maxParticipants Int                @default(10) @map("max_participants")
  currentCount    Int                @default(1) @map("current_count")
  tags            String[]
  status          ActivityStatus     @default(RECRUITING)
  contentCheck    ContentCheckStatus @default(PENDING) @map("content_check")
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")

  signups Signup[]

  @@index([status, startTime])
  @@index([type, status, startTime])
  @@index([locationLat, locationLng])
  @@index([creatorId, status])
  @@map("activities")
}

// =====================================================================
// Signups
// =====================================================================

enum SignupStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELED
}

model Signup {
  id         String       @id @default(cuid())
  activityId String       @map("activity_id")
  userId     String       @map("user_id")
  status     SignupStatus @default(APPROVED)
  message    String?      @db.VarChar(200)
  signedAt   DateTime     @default(now()) @map("signed_at")
  canceledAt DateTime?    @map("canceled_at")

  activity Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id])

  @@unique([activityId, userId])
  @@index([userId, status])
  @@index([activityId, status])
  @@map("signups")
}

// =====================================================================
// Reviews (M3 — design stored here so schema is stable across milestones)
// =====================================================================

model Review {
  id         String   @id @default(cuid())
  activityId String   @map("activity_id")
  fromUserId String   @map("from_user_id")
  toUserId   String   @map("to_user_id")
  rating     Int
  comment    String?  @db.VarChar(500)
  createdAt  DateTime @default(now()) @map("created_at")

  @@unique([activityId, fromUserId, toUserId])
  @@index([toUserId])
  @@map("reviews")
}

// =====================================================================
// Push tokens (issue #27)
// =====================================================================
//
// One row per (user, device, channel). The `token` value is the
// platform-specific registration handle:
//   - WECHAT_TEMPLATE:  WeChat openid (re-keyed for template-send)
//   - TPNS:             TPNS device-token
//   - FCM:              FCM registration token
//   - APNS:             APNs device-token
//
// `lastSeenAt` is updated on every registration refresh; tokens
// older than 90 days with no refresh are GC'd by a background job
// (M3 W2 followup). The `(userId, channel, token)` unique index
// makes the registration idempotent — a fresh device-token for the
// same user on the same channel just upserts the row.

enum PushChannel {
  WECHAT_TEMPLATE @map("wechat_template")
  TPNS            @map("tpns")
  FCM             @map("fcm")
  APNS            @map("apns")

  @@map("push_channel")
}

model PushToken {
  id         String      @id @default(cuid())
  userId     String      @map("user_id")
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel    PushChannel
  /// Platform-specific registration handle. Free-form string so we
  /// can pass through any token format without re-migrating.
  token      String      @db.VarChar(500)
  /// Optional device metadata: model name, OS version, locale,
  /// install id, app version, etc. Free-form JSON encoded as text
  /// (Prisma's `Json` type requires Postgres 9.4+; we already have
  /// it but a text column is simpler for the M3 stub).
  deviceInfo String?     @map("device_info") @db.Text
  createdAt  DateTime    @default(now()) @map("created_at")
  lastSeenAt DateTime    @default(now()) @map("last_seen_at")

  @@unique([userId, channel, token])
  @@index([userId])
  @@index([channel, lastSeenAt])
  @@map("push_tokens")
}
