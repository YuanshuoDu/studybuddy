# Server env (example — copy to .env and fill in)

NODE_ENV=development
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info

# Database
DATABASE_URL=postgresql://pairhub:pairhub@localhost:5432/pairhub

# Redis
REDIS_URL=redis://localhost:6379

# JWT (CHANGE in production — must be >= 32 chars)
JWT_SECRET=dev-secret-please-change-me-min-32-chars-aaaaa

# WeChat Mini Program (apply at https://mp.weixin.qq.com/)
WX_APPID=your-wx-appid
WX_SECRET=your-wx-app-secret

# CORS
CORS_ORIGIN=*
