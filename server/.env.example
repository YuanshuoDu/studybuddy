# Server env (example — copy to .env and fill in)
# All values must be overridden in production via your secret manager.

# ---- Runtime ----
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info

# ---- Database ----
# Local dev: matches infra/dev-up.sh (or docker-compose defaults)
DATABASE_URL=postgresql://studybuddy:studybuddy@localhost:5432/studybuddy

# ---- Redis ----
REDIS_URL=redis://localhost:6379

# ---- Auth ----
# Generate with: openssl rand -base64 48
# MUST be >= 32 chars in production.
JWT_SECRET=dev-secret-please-change-me-min-32-chars-aaaaa

# ---- CORS ----
# Comma-separated origins, or `*` for any. Set explicit origins in prod.
CORS_ORIGIN=*

# ---- Rate limit ----
# Requests per minute per IP for the global limit.
RATE_LIMIT_MAX=100
# Login endpoints get a tighter bucket.
RATE_LIMIT_LOGIN_MAX=10
