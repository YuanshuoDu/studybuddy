.create {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  padding: 32rpx 32rpx 200rpx;
  background: var(--color-bg);
}

.create__steps {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0 48rpx;
}

.create__step {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
  position: relative;
  color: var(--color-text-placeholder);
}

.create__step:not(:last-child)::after {
  content: '';
  position: absolute;
  top: 24rpx;
  left: calc(50% + 32rpx);
  right: calc(-50% + 32rpx);
  height: 2rpx;
  background: var(--color-border);
}

.create__step.is-active {
  color: var(--color-primary);
}

.create__step.is-active:not(:last-child)::after {
  background: var(--color-primary);
}

.create__step-dot {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: var(--color-bg-card);
  border: 2rpx solid var(--color-border);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
  z-index: 1;
}

.create__step.is-active .create__step-dot {
  background: var(--color-primary);
  border-color: var(--color-primary);
  color: #fff;
}

.create__step-label {
  font-size: 24rpx;
}

.create__panel {
  flex: 1;
}

.create__title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--color-text-primary);
  margin-bottom: 32rpx;
}

.create__type-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24rpx;
}

.create__type-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx 16rpx;
  background: var(--color-bg-card);
  border-radius: 16rpx;
  border: 2rpx solid transparent;
  transition: all 200ms ease;
}

.create__type-item.is-active {
  border-color: var(--color-primary);
  background: var(--color-primary-light);
}

.create__type-icon {
  font-size: 64rpx;
  margin-bottom: 12rpx;
}

.create__type-label {
  font-size: 26rpx;
  color: var(--color-text-primary);
}

.create__field {
  display: flex;
  align-items: flex-start;
  background: var(--color-bg-card);
  border-radius: 16rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 24rpx;
  min-height: 96rpx;
}

.create__field-label {
  width: 160rpx;
  font-size: 28rpx;
  color: var(--color-text-primary);
  flex-shrink: 0;
  line-height: 1.4;
}

.create__field-input,
.create__field-textarea {
  flex: 1;
  font-size: 28rpx;
  color: var(--color-text-primary);
  line-height: 1.5;
}

.create__field-textarea {
  height: 200rpx;
}

.create__field-value {
  flex: 1;
  font-size: 28rpx;
  color: var(--color-text-primary);
}
.create__field-value.is-placeholder {
  color: var(--color-text-placeholder);
}

.create__placeholder {
  color: var(--color-text-placeholder);
}

.create__summary {
  background: var(--color-bg-card);
  border-radius: 16rpx;
  padding: 16rpx 32rpx;
}

.create__summary-row {
  display: flex;
  align-items: flex-start;
  padding: 24rpx 0;
  border-bottom: 1rpx solid var(--color-divider);
}

.create__summary-row:last-child {
  border-bottom: none;
}

.create__summary-label {
  width: 120rpx;
  font-size: 26rpx;
  color: var(--color-text-secondary);
  flex-shrink: 0;
}

.create__summary-value {
  flex: 1;
  font-size: 28rpx;
  color: var(--color-text-primary);
  line-height: 1.5;
  word-break: break-word;
}

.create__footer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  gap: 16rpx;
  padding: 16rpx 32rpx;
  background: var(--color-bg-card);
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.create__btn {
  flex: 1;
  height: 88rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 500;
}

.create__btn--secondary {
  background: var(--color-primary-light);
  color: var(--color-primary);
}

.create__btn--primary {
  background: var(--color-primary);
  color: #fff;
}

.create__btn--primary.is-disabled {
  background: var(--color-text-placeholder);
  color: #fff;
}
