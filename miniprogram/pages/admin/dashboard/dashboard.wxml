<!--
  数据看板页（issue #32 前端 / docs/design/admin-glass.md §6.5）
  v2：玻璃面板用 class="glass ..." 全局类。
-->

<view class="dash page--dark {{reduceMotion ? 'reduce-motion' : ''}}" data-theme="{{theme}}">

  <view class="mesh" aria-hidden="true">
    <view class="mesh__blob mesh__blob--1"></view>
    <view class="mesh__blob mesh__blob--2"></view>
    <view class="mesh__blob mesh__blob--3"></view>
    <view class="mesh__blob mesh__blob--4"></view>
  </view>

  <view class="dash__content page-enter">

    <view class="dash__hero">
      <view class="dash__eyebrow">Pairhub · 运营</view>
      <view class="dash__title">数据看板</view>
      <view wx:if="{{generatedText}}" class="dash__sub">数据更新于 {{generatedText}}</view>
      <view wx:else class="dash__sub">正在拉取最新数据…</view>
    </view>

    <view wx:if="{{slaWarning}}" class="glass glass--radius-md glass--padding-md glass--tappable" hover-class="glass--hover" bindtap="onOpenActivitiesQueue">
      <view class="dash__sla">
        <view class="dash__sla-icon" aria-hidden="true">⚠</view>
        <view class="dash__sla-text">
          <view class="dash__sla-title">审核 SLA 告警</view>
          <view class="dash__sla-sub">当前待审核 {{metrics.activities.pending}} 条，已超过 20 条阈值，点击进入审核队列</view>
        </view>
      </view>
    </view>

    <view class="dash__grid">

      <view class="glass glass--radius-lg glass--padding-md glass--tappable" hover-class="glass--hover" bindtap="onCardUsers">
        <view class="metric">
          <view class="metric__icon metric__icon--users" aria-hidden="true">⚇</view>
          <view class="metric__label">用户</view>
          <view class="metric__value">{{metrics.users.total}}</view>
          <view class="metric__sub">
            <text class="metric__sub-block">
              <text class="metric__sub-num">{{metrics.users.newToday}}</text>
              <text class="metric__sub-label"> 今日新增</text>
            </text>
            <text class="metric__sub-block">
              <text class="metric__sub-num metric__sub-num--warn">{{metrics.users.banned}}</text>
              <text class="metric__sub-label"> 已封禁</text>
            </text>
          </view>
        </view>
      </view>

      <view class="glass glass--radius-lg glass--padding-md glass--tappable" hover-class="glass--hover" bindtap="onCardActivities">
        <view class="metric">
          <view class="metric__icon metric__icon--activities" aria-hidden="true">◆</view>
          <view class="metric__label">活动</view>
          <view class="metric__value">{{metrics.activities.total}}</view>
          <view class="metric__sub">
            <text class="metric__sub-block">
              <text class="metric__sub-num metric__sub-num--{{slaWarning ? 'danger' : 'accent'}}">{{metrics.activities.pending}}</text>
              <text class="metric__sub-label"> 待审核</text>
            </text>
            <text class="metric__sub-block">
              <text class="metric__sub-num metric__sub-num--success">{{metrics.activities.recruiting}}</text>
              <text class="metric__sub-label"> 招募中</text>
            </text>
          </view>
        </view>
      </view>

      <view class="glass glass--radius-lg glass--padding-md glass--tappable" hover-class="glass--hover" bindtap="onCardSignups">
        <view class="metric">
          <view class="metric__icon metric__icon--signups" aria-hidden="true">◇</view>
          <view class="metric__label">报名</view>
          <view class="metric__value">{{metrics.signups.total}}</view>
          <view class="metric__sub">
            <text class="metric__sub-block">
              <text class="metric__sub-num metric__sub-num--accent">{{metrics.signups.today}}</text>
              <text class="metric__sub-label"> 今日</text>
            </text>
            <text class="metric__sub-block">
              <text class="metric__sub-label">累计报名</text>
            </text>
          </view>
        </view>
      </view>

      <view class="glass glass--radius-lg glass--padding-md glass--tappable" hover-class="glass--hover" bindtap="onCardPushTokens">
        <view class="metric">
          <view class="metric__icon metric__icon--push" aria-hidden="true">⏚</view>
          <view class="metric__label">推送 Token</view>
          <view class="metric__value">{{metrics.pushTokens.total}}</view>
          <view class="metric__sub">
            <text class="metric__sub-block">
              <text class="metric__sub-label">已注册推送的设备数</text>
            </text>
            <text class="metric__sub-block">
              <text class="metric__sub-label">issue #27 已落地</text>
            </text>
          </view>
        </view>
      </view>
    </view>

    <view class="glass glass--radius-md glass--padding-md">
      <view class="dash__row-card">
        <view class="dash__row-icon" aria-hidden="true">↗</view>
        <view class="dash__row-body">
          <view class="dash__row-title">本周新增用户</view>
          <view class="dash__row-sub">最近 7 天累计注册</view>
        </view>
        <view class="dash__row-value">{{metrics.users.newThisWeek}}</view>
      </view>
    </view>

    <view class="dash__quick">
      <view class="glass glass--radius-md glass--padding-md glass--tappable" hover-class="glass--hover" bindtap="onOpenActivitiesQueue">
        <view class="dash__quick-icon dash__quick-icon--activities" aria-hidden="true">→</view>
        <view class="dash__quick-text">
          <view class="dash__quick-title">进入审核队列</view>
          <view class="dash__quick-sub">优先处理待审核活动</view>
        </view>
      </view>

      <view class="glass glass--radius-md glass--padding-md glass--tappable" hover-class="glass--hover" bindtap="onCardUsers">
        <view class="dash__quick-icon dash__quick-icon--users" aria-hidden="true">→</view>
        <view class="dash__quick-text">
          <view class="dash__quick-title">搜索用户</view>
          <view class="dash__quick-sub">按昵称 / 手机号 / id</view>
        </view>
      </view>
    </view>

    <view wx:if="{{errorMsg}}" class="dash__error">
      <text class="dash__error-icon" aria-hidden="true">!</text>
      <text class="dash__error-text">{{errorMsg}}</text>
      <view class="dash__error-btn" bindtap="onRefresh" role="button">重试</view>
    </view>

  </view>
</view>