/**
 * 审核队列页样式（issue #32 前端）
 *
 * mesh 背景层、玻璃内容层、状态芯片、行内操作按钮。
 * 不在这里写业务色 — 全部用 glass / status-pill / 现有语义 token。
 */

.aa {
  position: relative;
  min-height: 100vh;
  background: var(--admin-page-bg, #0B1020);
  color: var(--admin-text-primary);
  padding: 48rpx 32rpx 96rpx;
  overflow: hidden;
}
/* ---------- mesh ---------- */
.mesh { position: absolute; inset: 0; z-index: 0; overflow: hidden; pointer-events: none; }
.mesh__blob {
  position: absolute;
  width: 480rpx; height: 480rpx;
  border-radius: 50%;
  filter: blur(var(--mesh-blur, 100rpx));
  mix-blend-mode: screen;
  opacity: 0.85;
  animation: aa-mesh-drift 60s linear infinite;
  will-change: transform;
}
.mesh__blob--1 { left: -120rpx; top: -120rpx; background: radial-gradient(circle, var(--mesh-1) 0%, transparent 70%); }
.mesh__blob--2 { right: -160rpx; top: 200rpx; background: radial-gradient(circle, var(--mesh-2) 0%, transparent 70%); animation-delay: -15s; }
.mesh__blob--3 { left: 25%; bottom: -200rpx; background: radial-gradient(circle, var(--mesh-3) 0%, transparent 70%); animation-delay: -30s; }
.mesh__blob--4 { right: 20%; bottom: 80rpx; background: radial-gradient(circle, var(--mesh-4) 0%, transparent 70%); animation-delay: -45s; }
@keyframes aa-mesh-drift {
  0%   { transform: translate(0,0) scale(1); }
  50%  { transform: translate(40rpx, -30rpx) scale(1.05); }
  100% { transform: translate(0,0) scale(1); }
}
.reduce-motion .mesh__blob { animation: none; }
/* ---------- content ---------- */
.aa__content {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  gap: 32rpx;
  max-width: 720rpx;
  margin: 0 auto;
}

.aa__hero { padding: 16rpx 8rpx 0; }
.aa__eyebrow {
  font-size: 22rpx;
  font-weight: 500;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--admin-text-tertiary);
  margin-bottom: 6rpx;
}
.aa__title {
  font-size: 56rpx;
  font-weight: 600;
  line-height: 1.15;
  letter-spacing: -0.02em;
  color: var(--admin-text-primary);
  margin-bottom: 8rpx;
}
.aa__sub {
  font-size: 26rpx;
  color: var(--admin-text-secondary);
}
/* ---------- chips ---------- */
.aa__chips {
  white-space: nowrap;
  padding: 4rpx 0;
  -webkit-overflow-scrolling: touch;
}
.aa__chip {
  display: inline-flex;
  align-items: center;
  height: 64rpx;
  padding: 0 28rpx;
  margin-right: 16rpx;
  font-size: 24rpx;
  font-weight: 500;
  color: var(--admin-text-secondary);
  background: var(--glass-bg);
  -webkit-backdrop-filter: blur(var(--glass-blur-sm));
  backdrop-filter: blur(var(--glass-blur-sm));
  border: var(--glass-border);
  border-radius: var(--glass-radius-pill);
  line-height: 1.2;
}
.aa__chip.is-active {
  color: #fff;
  background: linear-gradient(135deg, var(--color-primary), #60A5FA);
  border-color: transparent;
  box-shadow: 0 4rpx 16rpx rgba(59, 130, 246, 0.4);
}
/* ---------- list ---------- */
.aa__list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  padding-bottom: 32rpx;
}
.aa__skel { padding: 8rpx 0; }
.aa__footer {
  text-align: center;
  font-size: 22rpx;
  color: var(--admin-text-tertiary);
  padding: 24rpx 0;
}
/* ---------- row card internals ---------- */
.row__top {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 12rpx;
}
.row__type {
  display: inline-flex;
  align-items: center;
  height: 36rpx;
  padding: 0 16rpx;
  border-radius: var(--glass-radius-pill);
  font-size: 20rpx;
  font-weight: 500;
  color: #fff;
}
.row__type--STUDY       { background: var(--color-activity-study); }
.row__type--SPORTS      { background: var(--color-activity-sport); }
.row__type--BOARD_GAME  { background: var(--color-activity-boardgame); }
.row__type--ONLINE_GAME { background: var(--color-activity-online-game); }
.row__type--OTHER       { background: var(--color-activity-other); }

.row__title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--admin-text-primary);
  line-height: 1.4;
  margin-bottom: 12rpx;
}

.row__meta {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  font-size: 22rpx;
  color: var(--admin-text-secondary);
}
.row__meta-item { display: flex; align-items: center; }
.row__meta-icon { margin-right: 8rpx; font-size: 22rpx; }
.row__meta-text { flex: 1; min-width: 0; }

.row__note {
  margin-top: 16rpx;
  padding: 12rpx 16rpx;
  border-radius: 16rpx;
  background: rgba(239, 68, 68, 0.10);
  border: 1rpx solid rgba(239, 68, 68, 0.25);
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}
.row__note-label {
  font-size: 20rpx;
  color: var(--color-error);
  font-weight: 500;
}
.row__note-text {
  font-size: 22rpx;
  color: var(--admin-text-primary);
  line-height: 1.5;
}
/* ---------- actions ---------- */
.row__actions {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
}
.row__btn {
  flex: 1;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  height: 80rpx;
  border-radius: var(--glass-radius-pill);
  font-size: 26rpx;
  font-weight: 500;
  border: var(--glass-border);
  background: var(--glass-bg);
  -webkit-backdrop-filter: blur(var(--glass-blur-sm));
  backdrop-filter: blur(var(--glass-blur-sm));
  transition: transform var(--motion-duration-fast, 120ms) ease-in-out;
}
.row__btn--primary {
  background: linear-gradient(135deg, var(--color-success), #16A34A);
  color: #fff;
  border-color: transparent;
  box-shadow: 0 4rpx 16rpx rgba(34, 197, 94, 0.4);
}
.row__btn--ghost {
  color: var(--color-error);
  background: rgba(239, 68, 68, 0.10);
  border-color: rgba(239, 68, 68, 0.30);
}
.row__btn--pressed,
.row__btn:active {
  transform: scale(0.98);
}
.row__btn-icon { font-size: 24rpx; line-height: 1; }
/* ---------- page-enter (brief §7) ---------- */
.page-enter { animation: aa-page-enter 320ms ease-out both; }
@keyframes aa-page-enter {
  0%   { opacity: 0; transform: translateY(8px); }
  100% { opacity: 1; transform: translateY(0); }
}
.reduce-motion .page-enter { animation: none; }
