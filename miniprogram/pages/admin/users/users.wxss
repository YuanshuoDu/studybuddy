/**
 * 用户搜索页样式（issue #32 前端）
 * 搜索框、状态芯片、行卡、action sheet 全部玻璃化。
 */

.au {
  position: relative;
  min-height: 100vh;
  background: var(--admin-page-bg, #0B1020);
  color: var(--admin-text-primary);
  padding: 48rpx 32rpx 96rpx;
  overflow: hidden;
}
/* ---------- mesh ---------- */
.mesh { position: absolute; inset: 0; z-index: 0; overflow: hidden; pointer-events: none; }
.mesh__blob {
  position: absolute;
  width: 480rpx; height: 480rpx;
  border-radius: 50%;
  filter: blur(var(--mesh-blur, 100rpx));
  mix-blend-mode: screen;
  opacity: 0.85;
  animation: au-mesh-drift 60s linear infinite;
  will-change: transform;
}
.mesh__blob--1 { left: -120rpx; top: -120rpx; background: radial-gradient(circle, var(--mesh-1) 0%, transparent 70%); }
.mesh__blob--2 { right: -160rpx; top: 200rpx; background: radial-gradient(circle, var(--mesh-2) 0%, transparent 70%); animation-delay: -15s; }
.mesh__blob--3 { left: 25%; bottom: -200rpx; background: radial-gradient(circle, var(--mesh-3) 0%, transparent 70%); animation-delay: -30s; }
.mesh__blob--4 { right: 20%; bottom: 80rpx; background: radial-gradient(circle, var(--mesh-4) 0%, transparent 70%); animation-delay: -45s; }
@keyframes au-mesh-drift {
  0%   { transform: translate(0,0) scale(1); }
  50%  { transform: translate(40rpx, -30rpx) scale(1.05); }
  100% { transform: translate(0,0) scale(1); }
}
.reduce-motion .mesh__blob { animation: none; }
/* ---------- content ---------- */
.au__content {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  max-width: 720rpx;
  margin: 0 auto;
}

.au__hero { padding: 8rpx 8rpx 0; }
.au__eyebrow {
  font-size: 22rpx; font-weight: 500; letter-spacing: 0.08em;
  text-transform: uppercase; color: var(--admin-text-tertiary);
  margin-bottom: 6rpx;
}
.au__title {
  font-size: 56rpx; font-weight: 600; line-height: 1.15;
  letter-spacing: -0.02em; color: var(--admin-text-primary);
  margin-bottom: 8rpx;
}
.au__sub { font-size: 24rpx; color: var(--admin-text-secondary); }
/* ---------- search field ---------- */
.au__search {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 8rpx 12rpx;
}
.au__search-icon {
  font-size: 32rpx;
  color: var(--admin-text-tertiary);
  flex-shrink: 0;
  width: 36rpx;
  text-align: center;
}
.au__search-input {
  flex: 1;
  font-size: 28rpx;
  color: var(--admin-text-primary);
  line-height: 1.5;
  min-width: 0;
  padding: 8rpx 0;
}
.au__search-placeholder { color: var(--admin-text-tertiary); }
.au__search-clear {
  width: 40rpx; height: 40rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.10);
  color: var(--admin-text-secondary);
  font-size: 28rpx;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}
/* ---------- chips ---------- */
.au__chips {
  white-space: nowrap;
  padding: 4rpx 0;
  -webkit-overflow-scrolling: touch;
}
.au__chip {
  display: inline-flex;
  align-items: center;
  height: 64rpx;
  padding: 0 28rpx;
  margin-right: 16rpx;
  font-size: 24rpx; font-weight: 500;
  color: var(--admin-text-secondary);
  background: var(--glass-bg);
  -webkit-backdrop-filter: blur(var(--glass-blur-sm));
  backdrop-filter: blur(var(--glass-blur-sm));
  border: var(--glass-border);
  border-radius: var(--glass-radius-pill);
  line-height: 1.2;
}
.au__chip.is-active {
  color: #fff;
  background: linear-gradient(135deg, var(--color-primary), #60A5FA);
  border-color: transparent;
  box-shadow: 0 4rpx 16rpx rgba(59, 130, 246, 0.4);
}
/* ---------- list / row ---------- */
.au__list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  padding-bottom: 32rpx;
}
.au__footer {
  text-align: center;
  font-size: 22rpx;
  color: var(--admin-text-tertiary);
  padding: 24rpx 0;
}

.row {
  display: flex;
  align-items: center;
  gap: 20rpx;
  transition: transform var(--motion-duration-fast, 120ms) ease-in-out;
}
.row--pressed,
.row:active { transform: scale(0.99); }

.row__avatar {
  width: 80rpx; height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--color-primary), #60A5FA);
  color: #fff;
  font-size: 32rpx; font-weight: 600;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}
.row__body { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 4rpx; }
.row__name {
  display: flex; align-items: center; gap: 12rpx;
  font-size: 28rpx; font-weight: 500; color: var(--admin-text-primary);
}
.row__sub {
  display: flex; align-items: center; gap: 6rpx;
  font-size: 22rpx; color: var(--admin-text-secondary);
  flex-wrap: wrap;
}
.row__sub-id { font-family: monospace; }
.row__sub-dot { opacity: 0.5; }
.row__sub-school { color: var(--admin-text-secondary); }
.row__sub-time { color: var(--admin-text-tertiary); }
.row__pills { flex-shrink: 0; }
/* ---------- action sheet ---------- */
.sheet { position: fixed; inset: 0; z-index: 50; display: flex; align-items: flex-end; justify-content: center; }
.sheet__backdrop {
  position: absolute; inset: 0;
  background: rgba(0, 0, 0, 0.55);
  -webkit-backdrop-filter: blur(8rpx);
  backdrop-filter: blur(8rpx);
  animation: au-sheet-fade 240ms cubic-bezier(0.32, 0.72, 0, 1);
}
.sheet__panel {
  position: relative;
  width: 100%;
  max-width: 720rpx;
  padding: 16rpx 32rpx 48rpx;
  background: var(--glass-bg-deep);
  -webkit-backdrop-filter: blur(var(--glass-blur-lg));
  backdrop-filter: blur(var(--glass-blur-lg));
  border-top: var(--glass-border);
  border-left: var(--glass-border);
  border-right: var(--glass-border);
  border-radius: 40rpx 40rpx 0 0;
  box-shadow: var(--glass-shadow-2);
  animation: au-sheet-rise 240ms cubic-bezier(0.32, 0.72, 0, 1);
  display: flex;
  flex-direction: column;
}
.sheet__handle { width: 80rpx; height: 8rpx; border-radius: 4rpx; background: rgba(255, 255, 255, 0.20); margin: 0 auto 24rpx; }
.sheet__title {
  font-size: 36rpx; font-weight: 600; color: var(--admin-text-primary);
  text-align: center; margin-bottom: 6rpx;
}
.sheet__sub {
  font-size: 22rpx; color: var(--admin-text-secondary);
  text-align: center; margin-bottom: 24rpx;
}
.sheet__target-status { display: flex; justify-content: center; margin-bottom: 24rpx; }
.sheet__actions { display: flex; gap: 16rpx; }
.sheet__btn {
  flex: 1;
  display: inline-flex; align-items: center; justify-content: center;
  height: 88rpx;
  border-radius: var(--glass-radius-pill);
  font-size: 28rpx; font-weight: 500;
  border: var(--glass-border);
  background: var(--glass-bg);
  transition: transform var(--motion-duration-fast, 120ms) ease-in-out;
}
.sheet__btn--ghost { color: var(--admin-text-primary); }
.sheet__btn--danger {
  background: linear-gradient(135deg, var(--color-error), #DC2626);
  color: #fff; border-color: transparent;
  box-shadow: 0 4rpx 16rpx rgba(239, 68, 68, 0.4);
}
.sheet__btn--primary {
  background: linear-gradient(135deg, var(--color-success), #16A34A);
  color: #fff; border-color: transparent;
  box-shadow: 0 4rpx 16rpx rgba(34, 197, 94, 0.4);
}
.sheet__btn--pressed,
.sheet__btn:active { transform: scale(0.98); }

@keyframes au-sheet-fade { 0% { opacity: 0; } 100% { opacity: 1; } }
@keyframes au-sheet-rise { 0% { transform: translateY(100%); } 100% { transform: translateY(0); } }
.reduce-motion .sheet__backdrop,
.reduce-motion .sheet__panel { animation: none; }
/* ---------- page-enter ---------- */
.page-enter { animation: au-page-enter 320ms ease-out both; }
@keyframes au-page-enter {
  0%   { opacity: 0; transform: translateY(8px); }
  100% { opacity: 1; transform: translateY(0); }
}
.reduce-motion .page-enter { animation: none; }
