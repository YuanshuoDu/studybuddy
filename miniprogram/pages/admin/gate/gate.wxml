<!--
  Admin 入口页（issue #32 前端 / docs/design/admin-glass.md §6.1）

  v2 (per verifier feedback on attempt 1)：玻璃面板用 class="glass ..." 全局
  类直接渲染（不再用 <glass-card> 组件）。
-->

<view class="gate page--dark {{reduceMotion ? 'reduce-motion' : ''}}" data-theme="{{theme}}">

  <view class="mesh" aria-hidden="true">
    <view class="mesh__blob mesh__blob--1"></view>
    <view class="mesh__blob mesh__blob--2"></view>
    <view class="mesh__blob mesh__blob--3"></view>
    <view class="mesh__blob mesh__blob--4"></view>
  </view>

  <view class="gate__content page-enter">

    <view class="gate__hero">
      <view class="gate__eyebrow">StudyBuddy · Admin</view>
      <view class="gate__title">管理员控制台</view>
      <view class="gate__sub">审核活动 · 维护用户 · 看板监控</view>
    </view>

    <view wx:if="{{checking}}" class="glass glass--radius-lg glass--padding-lg">
      <view class="gate__row">
        <view class="gate__spinner" aria-hidden="true"></view>
        <view class="gate__row-text">
          <view class="gate__row-title">正在校验身份</view>
          <view class="gate__row-sub">调取 /api/v1/users/me 验证 role</view>
        </view>
      </view>
    </view>

    <view wx:elif="{{role === 'ADMIN' && !errorMsg}}" class="glass glass--radius-lg glass--padding-lg">
      <view class="gate__row">
        <view class="gate__icon gate__icon--ok" aria-hidden="true">✓</view>
        <view class="gate__row-text">
          <view class="gate__row-title">检测到管理员身份</view>
          <view class="gate__row-sub">{{nickname}} · 正在进入数据看板…</view>
        </view>
      </view>
    </view>

    <block wx:elif="{{resolved && role !== 'ADMIN'}}">

      <view class="glass glass--radius-lg glass--padding-lg">
        <view class="gate__row">
          <view class="gate__icon gate__icon--warn" aria-hidden="true">!</view>
          <view class="gate__row-text">
            <view class="gate__row-title">需要管理员授权</view>
            <view class="gate__row-sub">
              {{errorMsg ? errorMsg : '当前账号 (' + (nickname || '匿名') + ') 的 role = USER'}}
            </view>
          </view>
        </view>
      </view>

      <view class="glass glass--radius-md glass--padding-md glass--tappable" hover-class="glass--hover" bindtap="onRefresh">
        <view class="gate__step">
          <view class="gate__step-num">1</view>
          <view class="gate__step-text">
            <view class="gate__step-title">重新探测身份</view>
            <view class="gate__step-sub">如果是最近才被授予的 admin，重新探测一次</view>
          </view>
          <view class="gate__step-cta">刷新</view>
        </view>
      </view>

      <view class="glass glass--radius-md glass--padding-md">
        <view class="gate__step">
          <view class="gate__step-num">2</view>
          <view class="gate__step-text">
            <view class="gate__step-title">在数据库中提升该用户为 ADMIN</view>
            <view class="gate__step-sub">在 ops 工具执行下方 SQL（一行搞定）</view>
          </view>
        </view>

        <view class="gate__sql">
          <text class="gate__sql-text" user-select="true">{{sqlHint}}</text>
        </view>

        <view class="gate__sql-actions">
          <view
            class="gate__btn gate__btn--primary"
            hover-class="gate__btn--pressed"
            bindtap="onCopySql"
            role="button"
            aria-label="复制 SQL 到剪贴板"
          >
            <text class="gate__btn-icon" aria-hidden="true">⧉</text>
            <text class="gate__btn-label">
              {{copyState === 'copied' ? '已复制' : (copyState === 'failed' ? '复制失败' : '复制 SQL')}}
            </text>
          </view>
        </view>

        <view class="gate__hint">
          见 docs/admin/playbook.md §1 — grant admin SQL one-liner
        </view>
      </view>

      <view class="glass glass-deep glass--radius-md glass--padding-md glass--tappable" hover-class="glass--hover" bindtap="onExit">
        <view class="gate__step">
          <view class="gate__step-num">3</view>
          <view class="gate__step-text">
            <view class="gate__step-title">回到首页</view>
            <view class="gate__step-sub">如果是误入，可以从这里退出</view>
          </view>
          <view class="gate__step-cta">返回</view>
        </view>
      </view>

    </block>

  </view>
</view>
