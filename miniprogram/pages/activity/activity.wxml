<view class="activity">
  <block wx:if="{{loading}}">
    <view class="activity__skeleton"></view>
  </block>

  <block wx:elif="{{!activity}}">
    <empty-state title="活动不存在" desc="可能已被删除" icon="🔍" />
  </block>

  <block wx:else>
    <view class="activity__cover" wx:if="{{activity.coverUrl}}">
      <image src="{{activity.coverUrl}}" mode="aspectFill" />
    </view>

    <view class="activity__card">
      <view class="activity__type activity__type--{{activity.type}}">{{typeLabel}}</view>
      <view class="activity__title">{{activity.title}}</view>

      <view class="activity__row">
        <text class="activity__icon">⏰</text>
        <view class="activity__row-text">
          <view>{{timeRange}}</view>
          <view class="activity__row-sub">{{deadlineText}}</view>
        </view>
      </view>

      <view class="activity__row">
        <text class="activity__icon">📍</text>
        <view class="activity__row-text">
          <view>{{activity.locationName}}</view>
          <view class="activity__row-sub">{{activity.locationAddr}}</view>
        </view>
      </view>

      <view class="activity__row">
        <text class="activity__icon">👥</text>
        <view class="activity__row-text">
          <view>{{activity.currentCount}} / {{activity.maxParticipants}} 人</view>
          <view class="activity__row-sub">{{statusLabel}}</view>
        </view>
      </view>
    </view>

    <view class="activity__card">
      <view class="activity__section-title">活动介绍</view>
      <view class="activity__desc">{{activity.description}}</view>
      <view class="activity__tags">
        <view class="activity__tag" wx:for="{{activity.tags}}" wx:key="*this">#{{item}}</view>
      </view>
    </view>
  </block>

  <!-- 底部操作栏 -->
  <view class="activity__footer">
    <view class="activity__footer-info">
      <view class="activity__footer-status">{{statusLabel}}</view>
    </view>
    <button
      class="btn-primary activity__footer-btn"
      bindtap="onSignup"
      loading="{{submitting}}"
      disabled="{{submitting || activity.isJoined || activity.status !== 'RECRUITING'}}"
    >
      {{activity.isJoined ? '已报名' : activity.status !== 'RECRUITING' ? '已截止' : '立即报名'}}
    </button>
  </view>
</view>
