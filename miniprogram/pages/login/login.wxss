.login {
  min-height: 100vh;
  padding: 96rpx 48rpx 64rpx;
  display: flex;
  flex-direction: column;
  background: var(--color-bg);
}

.login__hero {
  text-align: center;
  margin-bottom: 80rpx;
}

.login__logo {
  width: 144rpx;
  height: 144rpx;
  margin: 0 auto 32rpx;
  border-radius: 32rpx;
  background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
  color: #fff;
  font-size: 56rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  letter-spacing: -2rpx;
  box-shadow: var(--shadow-md);
}

.login__title {
  font-size: 56rpx;
  font-weight: 700;
  color: var(--color-text-primary);
  margin-bottom: 16rpx;
}

.login__subtitle {
  font-size: 28rpx;
  color: var(--color-text-secondary);
}

.login__tabs {
  display: flex;
  background: var(--color-bg-card);
  border-radius: 999rpx;
  padding: 8rpx;
  margin-bottom: 48rpx;
}

.login__tab {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 28rpx;
  color: var(--color-text-secondary);
  border-radius: 999rpx;
  transition: all 200ms ease;
}

.login__tab.is-active {
  background: var(--color-primary);
  color: #fff;
  font-weight: 500;
}

.login__panel {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.login__hint {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  text-align: center;
  margin-bottom: 48rpx;
}

.login__field {
  display: flex;
  align-items: center;
  background: var(--color-bg-card);
  border-radius: 16rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid var(--color-border);
}

.login__field-label {
  width: 120rpx;
  font-size: 28rpx;
  color: var(--color-text-primary);
}

.login__field-input {
  flex: 1;
  font-size: 30rpx;
  color: var(--color-text-primary);
}

.login__placeholder {
  color: var(--color-text-placeholder);
}

.login__sms-btn {
  font-size: 26rpx;
  color: var(--color-primary);
  padding: 8rpx 16rpx;
  border-left: 1rpx solid var(--color-border);
  margin-left: 16rpx;
  white-space: nowrap;
}

.login__sms-btn.is-disabled {
  color: var(--color-text-placeholder);
}

.login__btn {
  margin-top: 64rpx;
  height: 96rpx;
  font-size: 32rpx;
  border-radius: 999rpx;
}

.login__agreement {
  text-align: center;
  font-size: 24rpx;
  color: var(--color-text-secondary);
  margin-top: 32rpx;
  line-height: 1.6;
}

.login__switch {
  text-align: center;
  font-size: 26rpx;
  color: var(--color-text-secondary);
  margin-top: 32rpx;
}

.login__link {
  color: var(--color-primary);
}

.login__footer {
  text-align: center;
  font-size: 24rpx;
  color: var(--color-text-secondary);
  margin-top: 64rpx;
}
