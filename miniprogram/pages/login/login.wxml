<view class="login">
  <!-- 顶部 logo + slogan -->
  <view class="login__hero">
    <view class="login__logo">SB</view>
    <view class="login__title">Pairhub</view>
    <view class="login__subtitle">找到你的学习搭子</view>
  </view>

  <!-- Tab 切换 -->
  <view class="login__tabs">
    <view
      wx:for="{{tabs}}"
      wx:key="id"
      class="login__tab {{activeTab === item.id ? 'is-active' : ''}}"
      data-id="{{item.id}}"
      bindtap="onTabChange"
    >
      {{item.label}}
    </view>
  </view>

  <!-- 微信一键登录 -->
  <view wx:if="{{activeTab === 'wx'}}" class="login__panel">
    <view class="login__hint">使用微信账号快速登录，自动获取头像和昵称</view>
    <button
      class="btn-primary login__btn"
      bindtap="onWxLogin"
      loading="{{loading}}"
      disabled="{{loading}}"
    >
      微信一键登录
    </button>
    <view class="login__agreement">
      登录即代表同意
      <text class="login__link" bindtap="onAgreementTap">《用户协议》</text>
      和
      <text class="login__link" bindtap="onPrivacyTap">《隐私政策》</text>
    </view>
  </view>

  <!-- 手机号 + 验证码登录 -->
  <view wx:else class="login__panel">
    <view class="login__field">
      <text class="login__field-label">手机号</text>
      <input
        class="login__field-input"
        type="number"
        maxlength="11"
        placeholder="请输入手机号"
        placeholder-class="login__placeholder"
        value="{{phone}}"
        bindinput="onPhoneInput"
      />
    </view>
    <view class="login__field">
      <text class="login__field-label">验证码</text>
      <input
        class="login__field-input"
        type="number"
        maxlength="6"
        placeholder="请输入验证码"
        placeholder-class="login__placeholder"
        value="{{code}}"
        bindinput="onCodeInput"
      />
      <view
        class="login__sms-btn {{smsCountdown > 0 ? 'is-disabled' : ''}}"
        bindtap="onSendCode"
      >
        {{smsCountdown > 0 ? smsCountdown + 's 后重试' : '获取验证码'}}
      </view>
    </view>
    <button
      class="btn-primary login__btn"
      bindtap="onPhoneLogin"
      loading="{{loading}}"
      disabled="{{loading || !phone || !code}}"
    >
      登录
    </button>
    <view class="login__switch">
      收不到短信？
      <text class="login__link" bindtap="onSwitchToWx">使用微信登录</text>
    </view>
  </view>

  <view class="login__footer">
    <text>遇到问题？</text>
    <text class="login__link" bindtap="onContactTap">联系客服</text>
  </view>
</view>
