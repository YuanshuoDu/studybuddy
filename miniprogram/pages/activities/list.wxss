.alist {
  min-height: 100vh;
  padding: 16rpx 32rpx 32rpx;
  background: var(--color-bg);
}

.alist__chips {
  white-space: nowrap;
  padding: 8rpx 0 4rpx;
}

.alist__chips--sub {
  padding: 0 0 16rpx;
  border-bottom: 1rpx solid var(--color-divider);
  margin-bottom: 16rpx;
}

.alist__sub-row {
  display: flex; align-items: center; gap: 16rpx;
  margin-bottom: 16rpx;
}
.alist__sub-row .alist__chips--sub {
  flex: 1; padding: 0; border-bottom: none; margin-bottom: 0;
}
.alist__map-btn {
  display: flex; align-items: center; gap: 6rpx;
  padding: 8rpx 20rpx;
  background: var(--color-primary-container);
  color: var(--color-primary);
  border-radius: 999rpx;
  font-size: 24rpx; font-weight: 500;
  flex-shrink: 0;
  white-space: nowrap;
  line-height: 1.2;
}
.alist__map-btn:active {
  background: #BFDBFE;
}
.map-emoji { font-size: 28rpx; }
.map-label { font-size: 24rpx; }

.alist__chip {
  display: inline-block;
  padding: 12rpx 28rpx;
  margin-right: 16rpx;
  font-size: 26rpx;
  color: var(--color-text-secondary);
  background: var(--color-bg-card);
  border-radius: 999rpx;
  border: 1rpx solid var(--color-border);
  line-height: 1.2;
}

.alist__chip--sub {
  padding: 8rpx 22rpx;
  font-size: 24rpx;
}

.alist__chip.is-active {
  color: #fff;
  background: var(--color-primary);
  border-color: var(--color-primary);
  font-weight: 500;
}

.alist__list {
  padding-bottom: 32rpx;
}

.alist__empty {
  padding: 96rpx 0;
}

.alist__footer {
  text-align: center;
  font-size: 24rpx;
  color: var(--color-text-placeholder);
  padding: 32rpx 0;
}
