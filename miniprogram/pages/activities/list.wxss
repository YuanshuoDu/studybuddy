/* Activity list page — issue #22
 *
 * All colors / spacing / radius / shadow resolved via the design-system
 * tokens imported through app.wxss → styles/tokens.wxss.
 * See: docs/design/system-v1.md
 */

.alist {
  min-height: 100vh;
  padding: var(--space-sm) var(--space-lg) var(--space-lg);
  background: var(--color-bg);
}

.alist__chips {
  white-space: nowrap;
  padding: var(--space-xs) 0 var(--space-2xs);
}

.alist__chips--sub {
  padding: 0 0 var(--space-sm);
  border-bottom: 1rpx solid var(--color-divider);
  margin-bottom: var(--space-sm);
}

.alist__sub-row {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
  margin-bottom: var(--space-sm);
  padding: 0 var(--space-lg);
}

.alist__chip {
  display: inline-block;
  padding: var(--space-xs) var(--space-md);
  margin-right: var(--space-sm);
  font-size: var(--font-label-m);
  color: var(--color-text-secondary);
  background: var(--color-bg-card);
  border-radius: var(--radius-pill);
  border: 1rpx solid var(--color-border);
  line-height: 1.2;
  transition:
    background var(--motion-duration-fast) cubic-bezier(0.2, 0, 0, 1),
    color var(--motion-duration-fast) cubic-bezier(0.2, 0, 0, 1);
}

.alist__chip--sub {
  padding: var(--space-2xs) var(--space-sm);
  font-size: var(--font-body-s);
}

.alist__chip.is-active {
  color: var(--color-on-primary);
  background: var(--color-primary);
  border-color: var(--color-primary);
  font-weight: 500;
}

.alist__chip.is-active.alist__chip--study {
  background: var(--color-activity-study);
  border-color: var(--color-activity-study);
}
.alist__chip.is-active.alist__chip--sport {
  background: var(--color-activity-sport);
  border-color: var(--color-activity-sport);
}
.alist__chip.is-active.alist__chip--boardgame {
  background: var(--color-activity-boardgame);
  border-color: var(--color-activity-boardgame);
}
.alist__chip.is-active.alist__chip--online-game {
  background: var(--color-activity-online-game);
  border-color: var(--color-activity-online-game);
}
.alist__chip.is-active.alist__chip--other {
  background: var(--color-activity-other);
  border-color: var(--color-activity-other);
}

.alist__list {
  padding: 0 var(--space-lg) var(--space-lg);
}

.alist__empty {
  padding: var(--space-3xl) 0;
}

.alist__footer {
  text-align: center;
  font-size: var(--font-body-s);
  color: var(--color-text-placeholder);
  padding: var(--space-lg) 0;
}
