/* Activity detail page — issue #22
 *
 * All colors / spacing / radius / shadow resolved via the design-system
 * tokens imported through app.wxss → styles/tokens.wxss.
 * See: docs/design/system-v1.md
 */

.detail {
  min-height: 100vh;
  padding-bottom: 200rpx;
  background: var(--color-bg);
}

.detail__skeleton {
  height: 480rpx;
  background: linear-gradient(
    90deg,
    var(--color-surface-variant) 25%,
    var(--color-divider) 50%,
    var(--color-surface-variant) 75%
  );
  background-size: 200% 100%;
  animation: skel 1.2s infinite;
}

@keyframes skel {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

.detail__cover {
  width: 100%;
  height: 420rpx;
  background: var(--color-bg-card);
}
.detail__cover image {
  width: 100%;
  height: 100%;
}

.detail__card {
  background: var(--color-bg-card);
  margin: var(--space-md) var(--space-lg);
  padding: var(--space-lg);
  border-radius: var(--radius-md);
  box-shadow: var(--elevation-soft);
}

.detail__badges {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
  margin-bottom: var(--space-sm);
}

.detail__type,
.detail__status {
  display: inline-block;
  padding: 6rpx 20rpx;
  border-radius: var(--radius-pill);
  font-size: var(--font-label-m);
  color: var(--color-on-primary);
  font-weight: 500;
}
/* Activity type tints — sourced from --color-activity-* tokens */
.detail__type--STUDY       { background: var(--color-activity-study); }
.detail__type--SPORTS      { background: var(--color-activity-sport); }
.detail__type--BOARD_GAME  { background: var(--color-activity-boardgame); }
.detail__type--ONLINE_GAME { background: var(--color-activity-online-game); }
.detail__type--OTHER       { background: var(--color-activity-other); }
/* Activity status — full-saturation hero variants.
 * Soft variants: use the shared .status-badge--<STATUS> utility class
 * from app.wxss. */
.detail__status--RECRUITING { background: var(--color-success); }
.detail__status--FULL       { background: var(--color-warning); }
.detail__status--STARTED    { background: var(--color-info); }
.detail__status--ENDED      { background: var(--color-on-surface-variant); }
.detail__status--CANCELED   { background: var(--color-error); }

.detail__title {
  font-size: var(--font-headline-l);
  font-weight: 700;
  color: var(--color-text-primary);
  line-height: var(--line-snug);
}

.detail__row {
  display: flex;
  align-items: flex-start;
  padding: var(--space-sm) 0;
  border-top: 1rpx solid var(--color-divider);
}

.detail__row:first-of-type {
  border-top: none;
  padding-top: 0;
}

.detail__icon {
  width: 48rpx;
  font-size: var(--font-title-m);
  flex-shrink: 0;
  color: var(--color-primary);
}

.detail__row-text {
  flex: 1;
  font-size: var(--font-body-m);
  color: var(--color-text-primary);
  line-height: var(--line-normal);
}

.detail__row-sub {
  font-size: var(--font-body-s);
  color: var(--color-text-secondary);
  margin-top: var(--space-2xs);
}

.detail__section-title {
  font-size: var(--font-title-m);
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: var(--space-sm);
}

.detail__desc {
  font-size: var(--font-body-m);
  color: var(--color-text-regular);
  line-height: var(--line-cjk-relaxed);
  white-space: pre-wrap;
  word-break: break-word;
}

.detail__tags {
  display: flex;
  flex-wrap: wrap;
  margin-top: var(--space-sm);
  gap: var(--space-xs);
}

.detail__tag {
  padding: 6rpx 20rpx;
  font-size: var(--font-body-s);
  color: var(--color-primary);
  background: var(--color-primary-container);
  border-radius: var(--radius-pill);
}

.detail__map-name {
  font-size: var(--font-title-m);
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: var(--space-xs);
}

.detail__map-addr {
  font-size: var(--font-label-m);
  color: var(--color-text-regular);
  margin-bottom: var(--space-xs);
}

.detail__map-coord {
  display: flex;
  gap: var(--space-sm);
  font-size: var(--font-body-s);
  color: var(--color-text-secondary);
  font-family: monospace;
  margin-bottom: var(--space-sm);
}

.detail__map-placeholder {
  margin-top: var(--space-sm);
  padding: var(--space-2xl) var(--space-md);
  background: var(--color-bg);
  border-radius: var(--radius-md);
  text-align: center;
  font-size: var(--font-body-s);
  color: var(--color-text-placeholder);
  border: 1rpx dashed var(--color-border);
}

.detail__organizer {
  display: flex;
  align-items: center;
}

.detail__organizer-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: var(--radius-pill);
  background: var(--color-primary-container);
  color: var(--color-primary);
  font-size: var(--font-title-m);
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

.detail__organizer-info {
  margin-left: var(--space-md);
  flex: 1;
}

.detail__organizer-name {
  font-size: var(--font-title-m);
  color: var(--color-text-primary);
  font-weight: 500;
}

.detail__organizer-sub {
  font-size: var(--font-body-s);
  color: var(--color-text-secondary);
  margin-top: var(--space-2xs);
}

.detail__footer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  gap: var(--space-sm);
  padding: var(--space-sm) var(--space-lg);
  background: var(--color-bg-card);
  box-shadow: var(--elevation-medium);
  z-index: 10;
}

.detail__footer-btn {
  flex: 1;
  height: 88rpx;
  border-radius: var(--radius-pill);
  font-size: var(--font-body-m);
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.detail__footer-btn--main {
  flex: 2;
}
