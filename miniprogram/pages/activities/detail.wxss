.detail {
  min-height: 100vh;
  padding-bottom: 200rpx;
  background: var(--color-bg);
}

.detail__skeleton {
  height: 480rpx;
  background: linear-gradient(90deg, #f0f0f0 25%, #e8e8e8 50%, #f0f0f0 75%);
  background-size: 200% 100%;
  animation: skel 1.2s infinite;
}

@keyframes skel {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

.detail__cover {
  width: 100%;
  height: 420rpx;
  background: var(--color-bg-card);
}
.detail__cover image {
  width: 100%;
  height: 100%;
}

.detail__card {
  background: var(--color-bg-card);
  margin: 24rpx 32rpx;
  padding: 32rpx;
  border-radius: 16rpx;
  box-shadow: var(--shadow-sm);
}

.detail__badges {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.detail__type,
.detail__status {
  display: inline-block;
  padding: 6rpx 20rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  color: #fff;
  font-weight: 500;
}

.detail__type--STUDY { background: #4f8cff; }
.detail__type--SPORTS { background: #18bc6c; }
.detail__type--BOARD_GAME { background: #f5a623; }
.detail__type--ONLINE_GAME { background: #9b59b6; }
.detail__type--OTHER { background: #8a8a8a; }

.detail__status--RECRUITING { background: var(--color-success); }
.detail__status--FULL { background: var(--color-warning); }
.detail__status--STARTED { background: var(--color-primary); }
.detail__status--ENDED { background: var(--color-text-secondary); }
.detail__status--CANCELED { background: var(--color-danger); }

.detail__title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--color-text-primary);
  line-height: 1.4;
}

.detail__row {
  display: flex;
  align-items: flex-start;
  padding: 20rpx 0;
  border-top: 1rpx solid var(--color-divider);
}

.detail__row:first-of-type {
  border-top: none;
  padding-top: 0;
}

.detail__icon {
  width: 48rpx;
  font-size: 32rpx;
  flex-shrink: 0;
}

.detail__row-text {
  flex: 1;
  font-size: 28rpx;
  color: var(--color-text-primary);
  line-height: 1.5;
}

.detail__row-sub {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  margin-top: 4rpx;
}

.detail__section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 16rpx;
}

.detail__desc {
  font-size: 28rpx;
  color: var(--color-text-regular);
  line-height: 1.7;
  white-space: pre-wrap;
  word-break: break-word;
}

.detail__tags {
  display: flex;
  flex-wrap: wrap;
  margin-top: 16rpx;
  gap: 12rpx;
}

.detail__tag {
  padding: 6rpx 20rpx;
  font-size: 24rpx;
  color: var(--color-primary);
  background: var(--color-primary-light);
  border-radius: 999rpx;
}

.detail__map-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 8rpx;
}

.detail__map-addr {
  font-size: 26rpx;
  color: var(--color-text-regular);
  margin-bottom: 8rpx;
}

.detail__map-coord {
  display: flex;
  gap: 16rpx;
  font-size: 24rpx;
  color: var(--color-text-secondary);
  font-family: monospace;
  margin-bottom: 16rpx;
}

.detail__map-placeholder {
  margin-top: 16rpx;
  padding: 64rpx 24rpx;
  background: var(--color-bg);
  border-radius: var(--radius-md);
  text-align: center;
  font-size: 24rpx;
  color: var(--color-text-placeholder);
  border: 1rpx dashed var(--color-border);
}

.detail__organizer {
  display: flex;
  align-items: center;
}

.detail__organizer-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: var(--color-primary-light);
  color: var(--color-primary);
  font-size: 32rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

.detail__organizer-info {
  margin-left: 24rpx;
  flex: 1;
}

.detail__organizer-name {
  font-size: 30rpx;
  color: var(--color-text-primary);
  font-weight: 500;
}

.detail__organizer-sub {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  margin-top: 4rpx;
}

.detail__footer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 32rpx;
  background: var(--color-bg-card);
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.04);
  z-index: 10;
}

.detail__footer-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 999rpx;
  font-size: 28rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.detail__footer-btn--main {
  flex: 2;
}
