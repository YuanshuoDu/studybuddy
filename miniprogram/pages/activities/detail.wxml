<view class="detail">
  <block wx:if="{{loading}}">
    <view class="detail__skeleton"></view>
  </block>

  <block wx:elif="{{!activity}}">
    <empty-state title="活动不存在" desc="可能已被删除或链接有误" icon="🔍" />
  </block>

  <block wx:else>
    <view class="detail__cover" wx:if="{{activity.coverUrl}}">
      <image src="{{activity.coverUrl}}" mode="aspectFill" />
    </view>

    <view class="detail__card">
      <view class="detail__badges">
        <view class="detail__type detail__type--{{activity.type}}">{{typeLabel}}</view>
        <view class="detail__status detail__status--{{activity.status}}">{{statusLabel}}</view>
      </view>
      <view class="detail__title">{{activity.title}}</view>
    </view>

    <view class="detail__card">
      <view class="detail__row">
        <text class="detail__icon">⏰</text>
        <view class="detail__row-text">
          <view>{{timeRange}}</view>
          <view class="detail__row-sub">{{startText}} ~ {{endText}}</view>
        </view>
      </view>

      <view class="detail__row">
        <text class="detail__icon">📍</text>
        <view class="detail__row-text">
          <view>{{activity.locationName}}</view>
          <view class="detail__row-sub">{{activity.locationAddr}}</view>
        </view>
      </view>

      <view class="detail__row">
        <text class="detail__icon">👥</text>
        <view class="detail__row-text">
          <view>{{activity.currentCount}} / {{activity.maxParticipants}} 人</view>
          <view class="detail__row-sub">活动 ID: {{activity.id}}</view>
        </view>
      </view>
    </view>

    <view class="detail__card">
      <view class="detail__section-title">活动介绍</view>
      <view class="detail__desc">{{activity.description}}</view>
      <view class="detail__tags" wx:if="{{activity.tags.length}}">
        <view class="detail__tag" wx:for="{{activity.tags}}" wx:key="*this">#{{item}}</view>
      </view>
    </view>

    <!--
      地图占位：
      TODO(issue #35): 接入 Mapbox webview 决策（ADR-0006 已确定 B 方案）。
      当前仅展示 lat/lng + locationName，真实地图渲染由 issue #35 跟进。
    -->
    <view class="detail__card detail__map">
      <view class="detail__section-title">地点</view>
      <view class="detail__map-name">{{activity.locationName}}</view>
      <view class="detail__map-addr">{{activity.locationAddr}}</view>
      <view class="detail__map-coord">
        <text>lat {{activity.locationLat}}</text>
        <text>lng {{activity.locationLng}}</text>
      </view>
      <view class="detail__map-placeholder">[ 地图占位 — issue #35 接入 Mapbox webview ]</view>
    </view>

    <view class="detail__card">
      <view class="detail__section-title">组织者</view>
      <view class="detail__organizer">
        <view class="detail__organizer-avatar">{{activity.creatorId[0] || '?'}}</view>
        <view class="detail__organizer-info">
          <view class="detail__organizer-name">组织者</view>
          <view class="detail__organizer-sub">userId: {{activity.creatorId}}</view>
        </view>
      </view>
    </view>
  </block>

  <!-- 底部操作栏：创建者看“编辑 / 取消”，普通用户看“报名 / 已报名” -->
  <view wx:if="{{activity}}" class="detail__footer">
    <block wx:if="{{isCreator}}">
      <view class="btn-secondary detail__footer-btn" bindtap="onEdit">编辑</view>
      <view
        class="btn-primary detail__footer-btn {{activity.status === 'CANCELED' ? 'btn-disabled' : ''}}"
        bindtap="onCancelActivity"
      >
        {{activity.status === 'CANCELED' ? '已取消' : '取消活动'}}
      </view>
    </block>
    <block wx:else>
      <button
        class="btn-primary detail__footer-btn detail__footer-btn--main"
        bindtap="onSignup"
        loading="{{submitting}}"
        disabled="{{signupButtonDisabled}}"
      >
        {{signupButtonText}}
      </button>
    </block>
  </view>
</view>
