.profile {
  min-height: 100vh;
  background: var(--color-bg);
  padding-bottom: 64rpx;
}

.profile__header {
  display: flex;
  align-items: center;
  padding: 48rpx 32rpx 32rpx;
  background: linear-gradient(180deg, var(--color-primary-light) 0%, var(--color-bg) 100%);
}

.profile__avatar {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  background: var(--color-primary);
  color: #fff;
  font-size: 56rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-shadow: var(--shadow-md);
}

.profile__info {
  flex: 1;
  margin-left: 24rpx;
  min-width: 0;
}

.profile__name {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.profile__tag {
  font-size: 20rpx;
  color: var(--color-warning);
  background: #fff7e6;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  font-weight: 400;
}

.profile__bio {
  margin-top: 8rpx;
  font-size: 26rpx;
  color: var(--color-text-secondary);
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.profile__edit {
  padding: 12rpx 24rpx;
  font-size: 26rpx;
  color: var(--color-primary);
  background: var(--color-bg-card);
  border-radius: 999rpx;
  border: 1rpx solid var(--color-primary);
}

.profile__stats {
  display: flex;
  margin: 32rpx;
  padding: 32rpx 0;
  background: var(--color-bg-card);
  border-radius: 16rpx;
  box-shadow: var(--shadow-sm);
}

.profile__stat {
  flex: 1;
  text-align: center;
  border-right: 1rpx solid var(--color-divider);
}
.profile__stat:last-child { border-right: none; }

.profile__stat-num {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--color-text-primary);
}

.profile__stat-label {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  margin-top: 4rpx;
}

.profile__list {
  margin: 0 32rpx;
  background: var(--color-bg-card);
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: var(--shadow-sm);
}

.profile__list-item {
  display: flex;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid var(--color-divider);
}
.profile__list-item:last-child { border-bottom: none; }
.profile__list-item:active { background: #fafafa; }

.profile__list-icon {
  font-size: 36rpx;
  width: 48rpx;
}

.profile__list-text {
  flex: 1;
  font-size: 30rpx;
  color: var(--color-text-primary);
  margin-left: 16rpx;
}

.profile__list-arrow {
  font-size: 36rpx;
  color: var(--color-text-placeholder);
}

.profile__logout,
.profile__login {
  margin: 64rpx 32rpx 0;
  height: 88rpx;
  background: var(--color-bg-card);
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  color: var(--color-danger);
  box-shadow: var(--shadow-sm);
}

.profile__login {
  color: var(--color-primary);
}
