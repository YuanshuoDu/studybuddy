/**
 * 全局样式 + 主题变量
 *
 * 设计原则：
 * - 颜色 / 间距 / 字号 / 圆角 / 阴影 / 动效 全部在 tokens.wxss 中定义为 CSS
 *   自定义属性（design-system-v1），本文件只做导入、reset 与工具类聚合
 * - 不写具体业务的样式，全部走 components 或页面 .wxss
 * - 使用 rpx 适配（iPhone6 750 设计稿）
 *
 * 改主题：只改 tokens.wxss，全局生效。
 * 加主题：先在 docs/design/system-v1.md 提需求，再补到 tokens.wxss +
 *   Flutter tokens + HTML mockup 三端。
 */

@import './styles/tokens.wxss';

/* ========== Reset ========== */
page,
page view,
page text,
page image,
page button {
  box-sizing: border-box;
}

page {
  background: var(--color-bg);
  color: var(--color-text-primary);
  font-size: var(--font-body-m);
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', 'Microsoft YaHei', sans-serif;
  line-height: var(--line-cjk-body);
}

view,
text {
  -webkit-tap-highlight-color: transparent;
}

/* ========== 通用工具类 ========== */
.flex {
  display: flex;
}
.flex-col {
  display: flex;
  flex-direction: column;
}
.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}
.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.flex-1 {
  flex: 1;
}

.text-primary {
  color: var(--color-primary);
}
.text-secondary {
  color: var(--color-text-secondary);
}
.text-danger {
  color: var(--color-error);
}
.text-bold {
  font-weight: 600;
}

.bg-card {
  background: var(--color-bg-card);
  border-radius: var(--radius-md);
}

.ellipsis {
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}
.ellipsis-2 {
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.ellipsis-3 {
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* ========== Button 重置 ========== */
button {
  margin: 0;
  padding: 0;
  background: transparent;
  border: none;
  line-height: 1;
}
button::after {
  border: none;
}

/* ========== 主题色按钮 ========== */
.btn-primary {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 0 var(--space-lg);
  height: 88rpx;
  background: var(--color-primary);
  color: var(--color-text-inverse);
  border-radius: var(--radius-pill);
  font-size: var(--font-body-m);
  font-weight: 500;
  transition: background var(--motion-duration-fast) cubic-bezier(0.2, 0, 0, 1);
}
.btn-primary:active {
  background: var(--color-primary-active);
}
.btn-primary[disabled],
.btn-primary.btn-disabled {
  background: var(--color-text-placeholder);
  color: var(--color-text-inverse);
}

.btn-secondary {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 0 var(--space-lg);
  height: 88rpx;
  background: var(--color-primary-container);
  color: var(--color-primary);
  border-radius: var(--radius-pill);
  font-size: var(--font-body-m);
  font-weight: 500;
}

/* ========== Status badge utilities (shared across pages) ==========
 * Pages can apply these directly, e.g. <view class="status-badge status-badge--RECRUITING">招募中</view>
 * Mirrors `DesignColors` in Flutter.
 */
.status-badge {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 20rpx;
  border-radius: var(--radius-pill);
  font-size: var(--font-label-m);
  font-weight: 500;
  line-height: 1.4;
}
.status-badge--RECRUITING {
  background: var(--color-success-bg);
  color: var(--color-success);
}
.status-badge--FULL {
  background: var(--color-warning-bg);
  color: var(--color-warning);
}
.status-badge--STARTED {
  background: var(--color-info);
  color: var(--color-on-primary);
}
.status-badge--ENDED {
  background: var(--color-surface-variant);
  color: var(--color-on-surface-variant);
}
.status-badge--CANCELED {
  background: var(--color-error-bg);
  color: var(--color-error);
}
