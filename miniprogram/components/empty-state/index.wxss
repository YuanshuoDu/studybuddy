.es {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 64rpx 32rpx;
  text-align: center;
}

.es__icon {
  font-size: 96rpx;
  margin-bottom: 24rpx;
  opacity: 0.6;
}

.es__title {
  font-size: 30rpx;
  color: var(--color-text-primary);
  font-weight: 500;
  margin-bottom: 8rpx;
}

.es__desc {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  line-height: 1.6;
  max-width: 480rpx;
}

.es__action {
  margin-top: 32rpx;
  padding: 16rpx 40rpx;
  font-size: 26rpx;
  color: var(--color-primary);
  background: var(--color-primary-light);
  border-radius: 999rpx;
}
