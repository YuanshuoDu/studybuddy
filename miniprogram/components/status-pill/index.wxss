/**
 * status-pill WXSS
 *
 * v2 (per verifier feedback on attempt 1)：玻璃底由全局 .glass 类
 * (tokens.wxss) 提供；本文件只承载 .pill 的排版（gap / padding / 字号 /
 * 色点 / icon / text）。颜色经 .pill--{kind} 注入到 color（currentColor
 * 继承给 .pill__dot）。通过 styleIsolation: 'apply-shared' 让组件内部能
 * 使用全局 .glass 类，组件 WXSS 本身不重定义玻璃样式。
 */

.pill {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 6rpx 16rpx;
  font-size: 22rpx;
  line-height: 1.2;
  white-space: nowrap;
  vertical-align: middle;
}

.pill__dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: currentColor;
  flex-shrink: 0;
  box-shadow: 0 0 8rpx currentColor;
  opacity: 0.85;
}

.pill__icon {
  font-size: 22rpx;
  font-weight: 600;
  line-height: 1;
}
.pill__text {
  font-size: inherit;
  color: var(--admin-text-primary);
  font-weight: 500;
}

/* sizes */
.pill--sm {
  padding: 4rpx 12rpx;
  font-size: 20rpx;
  gap: 6rpx;
}
.pill--sm .pill__dot { width: 10rpx; height: 10rpx; }
.pill--sm .pill__icon { font-size: 20rpx; }

.pill--md {
  /* default — 上面已定义 */
}

/* kind — 颜色直接走现有语义 token，禁止引入新色（brief §5） */
.pill--pending   { color: var(--color-warning); }
.pill--active    { color: var(--color-success); }
.pill--banned    { color: var(--color-error); }
.pill--rejected  { color: var(--color-error); }
.pill--recruiting{ color: var(--color-primary); }
.pill--neutral   { color: var(--color-text-secondary); }