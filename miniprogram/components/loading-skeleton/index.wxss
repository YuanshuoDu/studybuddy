.ls {
  padding: 24rpx 0;
}

.ls__item {
  display: flex;
  background: var(--color-bg-card);
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  padding: 24rpx;
  box-shadow: var(--shadow-sm);
}

.ls__avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 16rpx;
  background: linear-gradient(90deg, #f0f0f0 25%, #e8e8e8 50%, #f0f0f0 75%);
  background-size: 200% 100%;
  animation: skel 1.2s infinite;
  flex-shrink: 0;
}

.ls__body {
  flex: 1;
  margin-left: 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.ls__line {
  height: 20rpx;
  border-radius: 4rpx;
  background: linear-gradient(90deg, #f0f0f0 25%, #e8e8e8 50%, #f0f0f0 75%);
  background-size: 200% 100%;
  animation: skel 1.2s infinite;
  margin: 8rpx 0;
}

.ls__line--1 { height: 32rpx; }
.ls__line--2 { height: 24rpx; }
.ls__line--3 { height: 24rpx; width: 60%; }

@keyframes skel {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}
