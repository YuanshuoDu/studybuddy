/**
 * Design tokens — miniprogram side of the Pairhub design system.
 * Spec: docs/design/system-v1.md. Mirror of app/lib/core/theme/design_tokens.dart.
 *
 * Imported globally via `@import './styles/tokens.wxss';` in miniprogram/app.wxss.
 * Do not introduce new color hex / spacing values inline; reference these tokens.
 */

page {
  /* ----- Color: brand & semantic ----- */
  --color-primary: #3B82F6;
  --color-primary-container: #DBEAFE;
  --color-on-primary: #FFFFFF;
  --color-primary-active: #2563EB;

  --color-success: #22C55E;
  --color-success-bg: #DCFCE7;
  --color-warning: #F59E0B;
  --color-warning-bg: #FEF3C7;
  --color-error: #EF4444;
  --color-error-bg: #FEE2E2;
  --color-info: #3B82F6;

  /* ----- Color: surface & text ----- */
  --color-bg: #F8FAFC;
  --color-surface: #FFFFFF;
  --color-surface-variant: #F1F5F9;
  --color-bg-card: #FFFFFF;
  --color-divider: #E2E8F0;
  --color-border: #CBD5E1;

  --color-text-primary: #0F172A;
  --color-text-secondary: #475569;
  --color-text-regular: #334155;
  --color-text-placeholder: #94A3B8;
  --color-text-inverse: #FFFFFF;
  --color-on-surface-variant: #475569;

  /* ----- Color: activity type tints ----- */
  --color-activity-study: #3B82F6;
  --color-activity-sport: #22C55E;
  --color-activity-boardgame: #A855F7;
  --color-activity-online-game: #EF4444;
  --color-activity-other: #64748B;

  /* ----- Typography: scale (rpx on iPhone6 750 design baseline) ----- */
  --font-display-m: 64rpx;
  --font-headline-l: 56rpx;
  --font-headline-m: 48rpx;
  --font-headline-s: 40rpx;
  --font-title-l: 44rpx;
  --font-title-m: 36rpx;
  --font-title-s: 32rpx;
  --font-body-l: 32rpx;
  --font-body-m: 28rpx;
  --font-body-s: 24rpx;
  --font-label-l: 28rpx;
  --font-label-m: 24rpx;
  --font-label-s: 22rpx;

  /* ----- Typography: line-height (CJK-tuned) ----- */
  --line-snug: 1.30;
  --line-normal: 1.50;
  --line-cjk-body: 1.55;
  --line-cjk-relaxed: 1.65;

  /* ----- Spacing (4-pt base; rpx at 750 baseline) ----- */
  --space-2xs: 4rpx;
  --space-xs: 8rpx;
  --space-sm: 16rpx;
  --space-md: 24rpx;
  --space-lg: 32rpx;
  --space-xl: 48rpx;
  --space-2xl: 64rpx;
  --space-3xl: 96rpx;
  --space-huge: 128rpx;

  /* ----- Radius ----- */
  --radius-sm: 8rpx;
  --radius-md: 16rpx;
  --radius-lg: 24rpx;
  --radius-xl: 32rpx;
  --radius-pill: 999rpx;

  /* ----- Elevation (1rpx = 0.5px on iPhone6, render as 1-2px in mini) ----- */
  --elevation-soft: 0 1rpx 2rpx rgba(0, 0, 0, 0.04);
  --elevation-medium: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
  --elevation-raised: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);

  /* ----- Motion ----- */
  --motion-duration-fast: 120ms;
  --motion-duration-base: 200ms;
  --motion-duration-slow: 360ms;
}
