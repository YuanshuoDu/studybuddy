# Pairhub Flutter app env config.
# All keys optional - app falls back to safe defaults via dotenv.maybeGet().
# This file exists so flutter_dotenv has something to load in dev / CI.
API_BASE_URL=
API_TIMEOUT_MS=
APPLE_CLIENT_ID=
GOOGLE_WEB_CLIENT_ID=
# Issue #35 — Mapbox public access token. NEVER commit a real token;
# the placeholder here makes the map screen fall back to a friendly
# "configure your token" view (see MapboxConfig.isConfigured).
MAPBOX_ACCESS_TOKEN=pk.PLACEHOLDER_REPLACE_AT_BUILD_TIME
