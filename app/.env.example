# studybuddy_app/.env.example
# Copy this file to assets/.env (and adjust values) before running the app.
# Loaded at startup by flutter_dotenv.

# Base API URL. iOS simulator can use localhost directly; Android emulator must use 10.0.2.2.
API_BASE_URL=https://api.studybuddy.local

# Optional request timeout in milliseconds.
API_TIMEOUT_MS=15000

# OAuth client IDs (placeholders — replace with real values when issued).
APPLE_CLIENT_ID=com.studybuddy.app
GOOGLE_WEB_CLIENT_ID=000000000000-placeholder.apps.googleusercontent.com
GOOGLE_IOS_CLIENT_ID=000000000000-placeholder.apps.googleusercontent.com
